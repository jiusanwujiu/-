{"id": "rule_006", "priority": 1, "condition": "任何可能影响外部的操作", "action": "先确认，不擅自行动（安全红线）", "description": "外部操作 → 先确认不擅自行动", "trigger_keywords": ["删除", "发送", "发布", "推送", "deploy", "push", "delete", "send", "publish", "commit", "PR", "merge", "rmdir", "格式化", "清空", "提交", "rebuild", "curl", "wget"], "trigger_signal_types": [], "trigger_if_query": false, "trigger_count": 8, "enabled": true}
